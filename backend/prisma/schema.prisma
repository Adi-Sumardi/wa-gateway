datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  admin
  operator
  viewer
}

enum DeviceStatus {
  connecting
  connected
  disconnected
  banned
}

enum MessageDirection {
  inbound
  outbound
}

enum MessageStatus {
  queued
  sent
  delivered
  read
  failed
}

enum BroadcastStatus {
  draft
  scheduled
  running
  paused
  completed
  failed
}

enum WarmerStatus {
  active
  paused
}

model User {
  id            String     @id @default(uuid()) @db.Uuid
  name          String
  email         String     @unique
  passwordHash  String     @map("password_hash")
  role          Role       @default(operator)
  isActive      Boolean    @default(true) @map("is_active")
  aiCreditBalance Int      @default(0) @map("ai_credit_balance")
  createdAt     DateTime   @default(now()) @map("created_at")
  devices       Device[]
  apiKeys       ApiKey[]
  auditLogs     AuditLog[]
  warmerSessions WarmerSession[]

  @@map("users")
}

enum CreditTransactionType {
  topup
  consumption
  adjustment
}

model AiCreditTransaction {
  id           String                 @id @default(uuid()) @db.Uuid
  userId       String                 @db.Uuid @map("user_id")
  amount       Int
  balanceAfter Int                    @map("balance_after")
  type         CreditTransactionType
  note         String?                @db.Text
  createdBy    String?                @db.Uuid @map("created_by")
  createdAt    DateTime               @default(now()) @map("created_at")

  @@map("ai_credit_transactions")
}

model Device {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String       @db.Uuid @map("user_id")
  label           String
  phoneNumber     String?      @map("phone_number")
  status          DeviceStatus @default(disconnected)
  sessionData     String?      @db.Text @map("session_data")
  lastConnectedAt DateTime?    @map("last_connected_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  aiEnabled       Boolean      @default(false) @map("ai_enabled")
  aiContext       String?      @db.Text @map("ai_context")
  // Structured resources the AI auto-reply can reference/attach - kept
  // separate from the freeform aiContext so the backend can act on them
  // deterministically (e.g. auto-attach the brochure image) instead of
  // relying on the LLM to remember to mention them.
  aiWebsiteUrl    String?      @map("ai_website_url")
  aiBrochureUrl   String?      @map("ai_brochure_url")
  aiPriceList     String?      @db.Text @map("ai_price_list")
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages        Message[]
  broadcasts      Broadcast[]
  warmerDevices   WarmerDevice[]

  @@map("devices")
}

model Contact {
  id          String               @id @default(uuid()) @db.Uuid
  // Nullable + backfilled rather than required: adding a required FK to a
  // table with existing production rows can't be pushed non-interactively
  // without a default. See ownership.service.ts:backfillLegacyOwnership.
  userId      String?              @db.Uuid @map("user_id")
  name        String
  phoneNumber String               @map("phone_number")
  tags        Json?                // Array of string tags
  notes       String?              @db.Text
  optedOut    Boolean              @default(false) @map("opted_out")
  createdAt   DateTime             @default(now()) @map("created_at")
  memberships ContactGroupMember[]
  messages    Message[]
  broadcastTargets BroadcastTarget[]

  @@unique([userId, phoneNumber])
  @@map("contacts")
}

model ContactGroup {
  id          String               @id @default(uuid()) @db.Uuid
  userId      String?              @db.Uuid @map("user_id")
  name        String
  description String?              @db.Text
  createdAt   DateTime             @default(now()) @map("created_at")
  members     ContactGroupMember[]

  @@map("contact_groups")
}

model ContactGroupMember {
  id        String       @id @default(uuid()) @db.Uuid
  contactId String       @db.Uuid @map("contact_id")
  groupId   String       @db.Uuid @map("group_id")
  contact   Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  group     ContactGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([contactId, groupId])
  @@map("contact_group_members")
}

model Template {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String?     @db.Uuid @map("user_id")
  name       String
  content    String      @db.Text
  mediaUrl   String?     @map("media_url")
  mediaType  String      @default("none") @map("media_type") // none, image, document, video
  createdAt  DateTime    @default(now()) @map("created_at")
  broadcasts Broadcast[]

  @@map("templates")
}

model Broadcast {
  id               String          @id @default(uuid()) @db.Uuid
  templateId       String?         @db.Uuid @map("template_id")
  deviceId         String          @db.Uuid @map("device_id")
  createdBy        String          @db.Uuid @map("created_by")
  name             String
  status           BroadcastStatus @default(draft)
  scheduledAt      DateTime?       @map("scheduled_at")
  delayMinSeconds  Int             @default(5) @map("delay_min_seconds")
  delayMaxSeconds  Int             @default(15) @map("delay_max_seconds")
  sleepEnabled     Boolean         @default(false) @map("sleep_enabled")
  sleepStart       Int             @default(22) @map("sleep_start")
  sleepEnd         Int             @default(7) @map("sleep_end")
  rotateDevices    Boolean         @default(false) @map("rotate_devices")
  createdAt        DateTime        @default(now()) @map("created_at")
  template         Template?       @relation(fields: [templateId], references: [id], onDelete: SetNull)
  device           Device          @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  messages         Message[]
  targets          BroadcastTarget[]

  @@map("broadcasts")
}

model BroadcastTarget {
  id           String        @id @default(uuid()) @db.Uuid
  broadcastId  String        @db.Uuid @map("broadcast_id")
  contactId    String        @db.Uuid @map("contact_id")
  messageId    String?       @db.Uuid @map("message_id")
  status       MessageStatus @default(queued)
  failedReason String?       @db.Text @map("failed_reason")
  sentAt       DateTime?     @map("sent_at")
  broadcast    Broadcast     @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  contact      Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@map("broadcast_targets")
}

model Message {
  id           String           @id @default(uuid()) @db.Uuid
  deviceId     String           @db.Uuid @map("device_id")
  contactId    String           @db.Uuid @map("contact_id")
  broadcastId  String?          @db.Uuid @map("broadcast_id")
  direction    MessageDirection
  content      String           @db.Text
  mediaUrl     String?          @map("media_url")
  status       MessageStatus    @default(queued)
  failedReason String?          @db.Text @map("failed_reason")
  // WhatsApp's own message id for inbound messages, used to deduplicate
  // if whatsapp-web.js re-emits the same 'message' event (reconnect/resync).
  waMessageId  String?          @unique @map("wa_message_id")
  createdAt    DateTime         @default(now()) @map("created_at")
  device       Device           @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  contact      Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  broadcast    Broadcast?       @relation(fields: [broadcastId], references: [id], onDelete: SetNull)

  @@map("messages")
}

model WarmerSession {
  id                 String         @id @default(uuid()) @db.Uuid
  userId             String         @db.Uuid @map("user_id")
  name               String
  status             WarmerStatus   @default(paused)
  minIntervalMinutes Int            @default(15) @map("min_interval_minutes")
  maxIntervalMinutes Int            @default(45) @map("max_interval_minutes")
  activeHourStart    Int            @default(8) @map("active_hour_start")
  activeHourEnd      Int            @default(22) @map("active_hour_end")
  // Optional custom phrase pool (array of strings); falls back to a small
  // built-in Indonesian small-talk pool when empty/null.
  messagePool        Json?          @map("message_pool")
  createdAt          DateTime       @default(now()) @map("created_at")
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  devices            WarmerDevice[]
  logs               WarmerLog[]

  @@map("warmer_sessions")
}

model WarmerDevice {
  id              String        @id @default(uuid()) @db.Uuid
  warmerSessionId String        @db.Uuid @map("warmer_session_id")
  deviceId        String        @db.Uuid @map("device_id")
  warmerSession   WarmerSession @relation(fields: [warmerSessionId], references: [id], onDelete: Cascade)
  device          Device        @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([warmerSessionId, deviceId])
  @@map("warmer_devices")
}

model WarmerLog {
  id              String        @id @default(uuid()) @db.Uuid
  warmerSessionId String        @db.Uuid @map("warmer_session_id")
  fromDeviceId    String        @db.Uuid @map("from_device_id")
  toDeviceId      String        @db.Uuid @map("to_device_id")
  content         String        @db.Text
  status          MessageStatus @default(queued)
  failedReason    String?       @db.Text @map("failed_reason")
  createdAt       DateTime      @default(now()) @map("created_at")
  warmerSession   WarmerSession @relation(fields: [warmerSessionId], references: [id], onDelete: Cascade)

  @@map("warmer_logs")
}

model ApiKey {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid @map("user_id")
  keyHash    String    @unique @map("key_hash")
  plainKey   String?   @map("plain_key")
  label      String
  isActive   Boolean   @default(true) @map("is_active")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

model Webhook {
  id         String       @id @default(uuid()) @db.Uuid
  userId     String?      @db.Uuid @map("user_id")
  url        String
  eventTypes Json         @map("event_types") // e.g. ["message.in", "message.status", "device.status"]
  isActive   Boolean      @default(true) @map("is_active")
  createdAt  DateTime     @default(now()) @map("created_at")
  logs       WebhookLog[]

  @@map("webhooks")
}

model WebhookLog {
  id           String   @id @default(uuid()) @db.Uuid
  webhookId    String   @db.Uuid @map("webhook_id")
  eventType    String   @map("event_type")
  responseCode Int?     @map("response_code")
  payload      String   @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  webhook      Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@map("webhook_logs")
}

model Permission {
  key             String           @id
  label           String
  category        String
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  role           Role
  permissionKey  String     @map("permission_key")
  granted        Boolean    @default(false)
  permission     Permission @relation(fields: [permissionKey], references: [key], onDelete: Cascade)

  @@id([role, permissionKey])
  @@map("role_permissions")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  action    String
  detail    String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model LinkTracker {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String?   @db.Uuid @map("user_id")
  code          String    @unique
  originalUrl   String    @map("original_url") @db.Text
  clicks        Int       @default(0)
  createdAt     DateTime  @default(now()) @map("created_at")
  lastClickedAt DateTime? @map("last_clicked_at")

  @@map("link_trackers")
}
